# Guide

guide: {
  metrics: count: entity: 1
  metrics: count: path: 3
  metrics: count: method: 3

  entity: station: {
    path: "/public/partner/stations": {
      op: list: method: *GET
    }
    path: "/public/stations": {
      op: list: method: *GET
    }
    path: "/public/stations/{id}": {
      op: load: method: *GET
    }
  }

}